# AgentWork Docker 环境变量配置
# 复制此文件为 .env 并填入实际值

# 运行环境
NODE_ENV=production

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 配置文件路径
CONFIG_PATH=/app/config.yaml

# API 密钥 (根据需要配置)
API_KEY=your-api-key-here

# 数据库 URL (如果使用外部数据库)
DATABASE_URL=sqlite:/app/data/agentwork.db

# Redis 连接 URL (内部服务，通常不需要修改)
REDIS_URL=redis://redis:6379

# 可选：Redis 密码 (如果启用了认证)
# REDIS_PASSWORD=your-redis-password

# 可选：应用端口
# PORT=3000

# 可选：时区
TZ=Asia/Shanghai
