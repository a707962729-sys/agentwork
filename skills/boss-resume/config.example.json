    "步骤4": "简历自动导出到指定目录"
  },
  
  "API调用示例": {
    "keywords": "后端工程师 Go",
    "city": "北京",
    "experience": "5-10年",
    "education": "硕士",
    "limit": 10,
    "outputDir": "~/resumes/后端/",
    "cookieFile": "~/.agentwork/boss-cookies.json"
