    "city": "上海",
    "experience": "3-5年",
    "salary": "15-25K",
    "education": "本科",
    "limit": 20,
    "outputDir": "~/resumes/前端/"
  },
  
  "城市列表": [
    "北京", "上海", "广州", "深圳", "杭州",
