    "苏州", "天津", "郑州", "长沙", "厦门"
  ],
  
  "经验选项": [
    "不限", "应届生", "1年以下", "1-3年",
    "3-5年", "5-10年", "10年以上"
  ],
  
  "学历选项": [
    "不限", "大专", "本科", "硕士", "博士"
  ],
  
  "使用说明": {
    "步骤1": "登录Boss直聘并导出Cookie",
